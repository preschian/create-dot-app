{
  "name": "create-dot-app",
  "type": "module",
  "version": "3.0.0",
  "description": "A CLI tool to bootstrap Polkadot-based decentralized applications with multiple frontend frameworks",
  "repository": {
    "type": "git",
    "url": "https://github.com/preschian/create-dot-app.git",
    "directory": "cli"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "bin": {
    "create-dot-app": "dist/index.mjs"
  },
  "files": [
    "dist",
    "templates"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "prepack": "tsdown",
    "lint": "eslint src --fix",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.0",
    "fs-extra": "^11.3.5",
    "giget": "^3.2.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "strip-ansi": "^7.2.0",
    "tsdown": "^0.22.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
