import Features from '../components/landing/Features.astro';
import Stack from '../components/landing/Stack.astro';
import ClosingCTA from '../components/landing/ClosingCTA.astro';
import Footer from '../components/landing/Footer.astro';
---

<Layout>
  <div class="lp-root">
    <div class="lp-frame">
      <TopBar />
      <Hero />
      <Stats />
      <Quickstart />
      <Features />
      <Stack />
      <ClosingCTA />
      <Footer />
    </div>
  </div>
